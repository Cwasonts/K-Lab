(version 1)
(rule "Copper to edge clearance 1"
	(constraint edge_clearance (min 0.3mm))
)
(rule "Vias under SMD 1"
	(constraint disallow blind_via)
	(condition "A.Pad_Type == 'SMD'")
)
(rule "Copper to hole clearance 2"
	(constraint hole_clearance (min 0.00001mm))
)
(rule "Minimum clearance 2"
	(constraint clearance (min 0.1mm))
)
